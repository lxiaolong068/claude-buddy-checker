# Copy this file to .env.production and fill in your values before running `npm run build`.
# These variables are injected into index.html at build time by Vite.

# Umami analytics endpoint (e.g. https://analytics.yourdomain.com)
VITE_ANALYTICS_ENDPOINT=

# Umami website ID (UUID from your Umami dashboard)
VITE_ANALYTICS_WEBSITE_ID=
